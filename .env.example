SECRET_KEY=change-me-to-a-long-random-string
INSTRUCTOR_PASSWORD=change-me-instructor-only
LEARNER_PIN=change-me-student-sign-in

# Local dev on http://localhost — cookies work without HTTPS:
# FORCE_INSECURE_COOKIES=1
# FLASK_DEBUG=1

# Instructor-hosted Railway (before student repo exists) — register one learner:
# LEARNER_SLUG=student
# LEARNER_NAME=Student
# LEARNER_AGE=19

# Railway only — mount a volume at /data and set:
# DATA_DIR=/data
